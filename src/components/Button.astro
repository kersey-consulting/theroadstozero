---
interface Props {
  label: string;
  href?: string;
  theme?: 'primary' | 'secondary';
  size?: 'medium' | 'large';
}

const { label, href, theme = 'primary', size = 'medium' } = Astro.props;
---

{href ? (
  <a class:list={['button', theme, size]} href={href}>{label}</a>
) : (
  <button class:list={['button', theme, size]}>{label}</button>
)}

<style>
  .button {
    display: inline-block;
    text-align: center;
  }
  .button:hover,
  .button:focus {
    text-decoration: none;
  }
  .medium {
    padding: 1rem;
    margin: 1rem;
  }
  .large {
    width: 100%;
    padding: 1rem;
  }
  .primary {
    color: var(--color-primary);
    background: transparent;
    border: 2px solid;
    border-radius: 15px;
  }
  .primary:hover,
  .primary:focus {
    background: var(--color-surface);
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
  }
  .secondary {
    background: var(--color-primary);
    color: var(--color-surface);
    border: 2px solid;
    border-radius: 15px;
  }
  .secondary:hover,
  .secondary:focus {
    background: var(--color-primary-hover);
    color: var(--color-surface);
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
  }
</style>
