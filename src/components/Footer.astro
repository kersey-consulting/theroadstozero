---
import { sanityClient, queries } from '@/lib/sanity';

const settings = await sanityClient.fetch(queries.siteSettings).catch(() => null);

const EXTRA_LINKS = [
  { id: 'privacy', label: 'Privacy Policy', href: '/privacy' },
  { id: 'contact', label: 'Contact', href: '/contact' },
];

const socialSvgs: Record<string, string> = {
  facebook: '<svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg"><path d="M228,128A100,100,0,1,0,127.98877,228l.01123.001.01123-.001A100.11345,100.11345,0,0,0,228,128Zm-96,91.90771V148.001h28a4,4,0,0,0,0-8H132v-28a20.02229,20.02229,0,0,1,20-20h16a4,4,0,0,0,0-8H152a28.03145,28.03145,0,0,0-28,28v28H96a4,4,0,0,0,0,8h28v71.90673a92,92,0,1,1,8,0Z"></path></svg>',
  instagram: '<svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg"><path d="M128,84a44,44,0,1,0,44,44A44.04978,44.04978,0,0,0,128,84Zm0,80a36,36,0,1,1,36-36A36.04061,36.04061,0,0,1,128,164ZM172,32H84A52.059,52.059,0,0,0,32,84v88a52.059,52.059,0,0,0,52,52h88a52.059,52.059,0,0,0,52-52V84A52.059,52.059,0,0,0,172,32Zm44,140a44.04978,44.04978,0,0,1-44,44H84a44.04978,44.04978,0,0,1-44-44V84A44.04978,44.04978,0,0,1,84,40h88a44.04978,44.04978,0,0,1,44,44ZM188,76a8,8,0,1,1-8-8A8.00917,8.00917,0,0,1,188,76Z"></path></svg>',
  youtube: '<svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg"><path d="M162.21875,124.67188l-48-32A3.99967,3.99967,0,0,0,108,96v64a3.99987,3.99987,0,0,0,6.21875,3.32812l48-32a3.99979,3.99979,0,0,0,0-6.65624ZM116,152.52588V103.47412L152.78906,128Z"></path></svg>',
  tiktok: '<svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg"><path d="M224,80a52.059,52.059,0,0,1-52-52,4.0002,4.0002,0,0,0-4-4H128a4.0002,4.0002,0,0,0-4,4V156a24,24,0,1,1-34.28418-21.69238,3.99957,3.99957,0,0,0,2.28369-3.61279L92,89.05569a3.99948,3.99948,0,0,0-4.70117-3.938A72.00522,72.00522,0,1,0,172,156l-.00049-42.56348A99.27749,99.27749,0,0,0,224,128a4.0002,4.0002,0,0,0,4-4V84A4.0002,4.0002,0,0,0,224,80Z"></path></svg>',
};

const SOCIAL_LINKS = settings?.socialLinks?.map((l: any) => ({
  id: l.platform,
  label: l.platform,
  href: l.url,
})) ?? [
  { id: 'facebook', label: 'Facebook', href: 'https://www.facebook.com/theroadtozero0/' },
  { id: 'instagram', label: 'Instagram', href: 'https://www.instagram.com/theroadtozero0/' },
  { id: 'youtube', label: 'YouTube', href: 'https://www.youtube.com/@Theroadtozero0' },
  { id: 'tiktok', label: 'TikTok', href: 'https://www.tiktok.com/@Theroadtozero0' },
];

const CONTACT = [
  { text: settings?.email ?? 'info@theroadstozero.com' },
  { text: settings?.phone ? `(${settings.phone.slice(0,3)}) ${settings.phone.slice(4)}` : '(801) 682-7939' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="inner">
    <div class="columns">
      <section class="column" aria-label="Footer links">
        <h3 class="heading">Links</h3>
        <ul class="list">
          {EXTRA_LINKS.map(link => (
            <li class="listItem">
              <a class="link" href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </section>

      <section class="columnCenter" aria-label="About The Road to Zero">
        <img class="logo" src="/icons/gold-ring-logo.png" alt="The Road to Zero Logo" />
      </section>

      <section class="column" aria-label="Social media links">
        <h3 class="heading">Get in Touch</h3>
        <ul class="socialList">
          {SOCIAL_LINKS.map(link => (
            <li class="socialItem">
              <a class="socialLink" href={link.href} aria-label={link.label} target="_blank" rel="noopener noreferrer">
                <span class="socialIcon" aria-hidden="true" set:html={socialSvgs[link.id]} />
              </a>
            </li>
          ))}
        </ul>
        {CONTACT.map(c => (
          <div class="socialItem">
            <span class="contactText">{c.text}</span>
          </div>
        ))}
      </section>
    </div>

    <div>
      <p class="description">
        Disclaimer: These services are not intended to diagnose, treat, cure, or prevent any disease. The material on this brochure is provided for informational purposes only and is not medical advice or treatment. Always consult your physician before beginning any therapy program.
      </p>
    </div>

    <div class="bottomBar">
      <p class="copyright">
        The Road to Zero &copy; {year}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 3rem;
    box-shadow: 2px 2px 10px;
  }
  .inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: 2.5rem 2rem 1.5rem;
  }
  .columns {
    display: grid;
    grid-template-columns: minmax(160px, 0.8fr) minmax(280px, 2.4fr) minmax(160px, 0.8fr);
    gap: 2rem;
    align-items: start;
    max-width: 1200px;
    margin: auto;
  }
  .column { min-width: 200px; }
  .columnCenter {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }
  .list, .socialList {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .socialList { display: flex; }
  .link { font-size: 0.75rem; color: inherit; text-decoration: none; }
  .link:hover, .link:focus { text-decoration: underline; }
  .socialLink { display: inline-flex; align-items: center; gap: 0.6rem; color: inherit; text-decoration: none; }
  .socialLink:hover, .socialLink:focus { text-decoration: underline; }
  .logo {
    width: 220px;
    max-width: 100%;
    height: auto;
  }
  .description {
    margin: 2rem auto 0;
    max-width: 1200px;
    font-size: 0.8rem;
    line-height: 1.5;
    opacity: 0.9;
    text-align: center;
  }
  .socialIcon :global(svg) {
    width: 30px;
    height: 30px;
    display: block;
    fill: var(--color-primary);
  }
  .contactText { font-size: 0.75rem; }
  .bottomBar {
    font-size: 0.75rem;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    display: flex;
    justify-content: center;
  }
  @media (max-width: 975px) {
    .columns { grid-template-columns: 1fr; }
    .columnCenter { order: -1; }
  }
</style>
