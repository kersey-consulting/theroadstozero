---
interface Card {
  title: string;
  description?: string;
}
interface Props {
  section: { title?: string; intro?: string; cards?: Card[] };
  variant?: 'default' | 'alt';
}
const { section, variant = 'default' } = Astro.props;
---
<section class:list={['section', variant === 'alt' && 'sectionAlt']}>
  <div class="narrow">
    {section?.title && <h2 class="sectionTitleCentered">{section.title}</h2>}
    {section?.intro && <p class="centeredText">{section.intro}</p>}
    <div class="grid">
      {(section?.cards ?? []).map((card) => (
        <div class="card">
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .section, .sectionAlt { padding: 5rem 1.5rem; }
  .sectionAlt { background: rgba(210, 185, 150, 0.12); }
  .narrow { width: min(100%, 1000px); margin: 0 auto; }
  .sectionTitleCentered { margin: 0 0 1.5rem; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; text-align: center; }
  .centeredText { text-align: center; max-width: 760px; margin: 0 auto 2rem; font-size: 1.05rem; line-height: 1.85; }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; }
  .card { background: white; border-radius: 24px; padding: 2rem; box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08); }
  .card h3 { margin: 0 0 1rem; font-size: 1.25rem; }
  .card p { margin: 0; line-height: 1.7; white-space: pre-line; }
</style>
