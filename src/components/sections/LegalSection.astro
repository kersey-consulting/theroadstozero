---
interface Block {
  style?: string;
  children?: { text?: string }[];
}

interface Props {
  section: {
    title?: string;
    content?: Block[];
  };
  variant?: 'default' | 'alt';
}

const { section, variant = 'default' } = Astro.props;
const blocks = section?.content ?? [];
const toText = (block: Block) => block.children?.map((c) => c.text).join('')?.trim() ?? '';
---

<section class:list={['section', variant === 'alt' && 'sectionAlt']}>
  <div class="narrow">
    {section?.title && <h2 class="sectionTitle">{section.title}</h2>}
    <div class="copy">
      {blocks.map((block) => {
        const text = toText(block);
        if (!text) return null;
        if (block.style === 'h3') return <h3>{text}</h3>;
        if (block.style === 'h4') return <h4>{text}</h4>;
        if (block.style === 'blockquote') return <blockquote>{text}</blockquote>;
        return <p>{text}</p>;
      })}
    </div>
  </div>
</section>

<style>
  .section, .sectionAlt { padding: 5rem 1.5rem; }
  .sectionAlt { background: rgba(210, 185, 150, 0.12); }
  .narrow { width: min(100%, 1000px); margin: 0 auto; }
  .sectionTitle { margin: 0 0 1.5rem; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; }
  .copy { display: flex; flex-direction: column; gap: 1rem; }
  .copy p, .copy blockquote { margin: 0; font-size: 1.05rem; line-height: 1.85; }
  .copy h3, .copy h4 { margin: 1rem 0 0; line-height: 1.2; }
  .copy h3 { font-size: clamp(1.35rem, 2vw, 1.7rem); }
  .copy h4 { font-size: clamp(1.15rem, 1.8vw, 1.35rem); }
  .copy blockquote { padding-left: 1rem; border-left: 3px solid rgba(185, 149, 94, 0.5); font-style: italic; }
  @media (max-width: 900px) { .section, .sectionAlt { padding: 4rem 1.25rem; } }
</style>
