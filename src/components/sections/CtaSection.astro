---
import Button from '@/components/Button.astro';
interface Props { section: { title?: string; text?: string; actions?: { label: string; href: string }[] } }
const { section } = Astro.props;
---
<section class="section">
  <div class="ctaCard">
    {section?.title && <h2 class="sectionTitleCentered">{section.title}</h2>}
    {section?.text && <p class="centeredText">{section.text}</p>}
    <div class="ctaActions">{(section?.actions ?? []).map((action) => <Button label={action.label} href={action.href} theme="primary" />)}</div>
  </div>
</section>
<style>
  .section { padding: 5rem 1.5rem; }
  .ctaCard { width: min(100%, 960px); margin: 0 auto; text-align: center; background: white; border-radius: 24px; padding: 2rem; box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08); }
  .sectionTitleCentered { margin: 0 0 1.5rem; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; text-align: center; }
  .centeredText { text-align: center; max-width: 760px; margin: 0 auto; font-size: 1.05rem; line-height: 1.85; }
  .ctaActions { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; margin-top: 2rem; }
</style>
