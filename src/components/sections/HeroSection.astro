---
import Hero from '@/components/Hero.astro';
import Button from '@/components/Button.astro';
import PortableInline from './PortableInline.astro';
import { portableNodes } from '@/lib/portableText';
import { urlFor } from '@/lib/sanity';

interface Action {
  label: string;
  href: string;
}

interface Props {
  section: {
    eyebrow?: string;
    title: string;
    content?: { style?: string; listItem?: string; children?: { text?: string }[] }[];
    image?: any;
    imageUrl?: string;
    imageShadow?: boolean;
    imageMaxWidth?: string;
    imagePosition?: 'left' | 'right';
    backgroundImage?: any;
    backgroundImageUrl?: string;
    actions?: Action[];
  };
}

const { section } = Astro.props;
const resolveImageUrl = (img: any) => {
  if (!img) return undefined;
  if (typeof img === 'string') return img;
  if (img.asset?.url) return img.asset.url;
  try {
    return urlFor(img).url();
  } catch {
    return undefined;
  }
};

const imageUrl = section?.imageUrl ?? resolveImageUrl(section?.image);
const backgroundImageUrl = section?.backgroundImageUrl ?? resolveImageUrl(section?.backgroundImage);
const imageStyle = section?.imageMaxWidth ? `width: ${section.imageMaxWidth};` : undefined;
const nodes = portableNodes(section?.content ?? []);
const actions = section?.actions ?? [];
const hasImage = Boolean(imageUrl);
const reverse = section?.imagePosition === 'left';
---

<Hero id="hero" backgroundImage={backgroundImageUrl} theme="tertiary" backgroundParallax={true} hasRightColumn={hasImage} reverse={reverse}>
  <div slot="left" class:list={['heroContent', !hasImage && 'fullWidth']}>
    {section?.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
    <h1 class="heroTitle">{section?.title}</h1>
    {nodes.length > 0 && (
      <div class="heroCopy">
        {nodes.map((node) => {
          if (node.type === 'bulletList') return <ul class="heroList">{node.items.map((item) => <li><PortableInline children={item} /></li>)}</ul>;
          if (node.type === 'h3') return <h3 class="heroSubheading"><PortableInline children={node.children} /></h3>;
          if (node.type === 'h4') return <h4 class="heroSubheadingSmall"><PortableInline children={node.children} /></h4>;
          if (node.type === 'blockquote') return <blockquote class="heroQuote"><PortableInline children={node.children} /></blockquote>;
          return <p class="heroText"><PortableInline children={node.children} /></p>;
        })}
      </div>
    )}
    {actions.length > 0 && (
      <div class="heroActions">
        {actions.map((action) => <Button label={action.label} href={action.href} theme="primary" />)}
      </div>
    )}
  </div>
  {imageUrl && <img slot="right" class:list={['heroImage', section?.imageShadow === false && 'heroImageFlat']} style={imageStyle} src={imageUrl} alt={section?.title ?? 'Hero image'} />}
</Hero>

<style>
  .heroContent { max-width: 720px; display: flex; flex-direction: column; gap: 1rem; }
  .heroContent.fullWidth { max-width: 100%; }
  .eyebrow { margin: 0; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.85rem; font-weight: 700; opacity: 0.8; }
  .heroTitle { margin: 0; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.05; }
  .heroCopy { display: flex; flex-direction: column; gap: 1rem; }
  .heroText, .heroQuote { margin: 0; font-size: 1.1rem; line-height: 1.75; }
  .heroSubheading, .heroSubheadingSmall { margin: 0; line-height: 1.2; }
  .heroSubheading { font-size: clamp(1.35rem, 2vw, 1.7rem); }
  .heroSubheadingSmall { font-size: clamp(1.15rem, 1.8vw, 1.35rem); }
  .heroQuote { padding-left: 1rem; border-left: 3px solid rgba(185, 149, 94, 0.5); font-style: italic; }
  .heroList { margin: 0; padding-left: 1.5rem; display: grid; gap: 0.65rem; font-size: 1.1rem; line-height: 1.75; }
  .heroList li { font-size: inherit; line-height: inherit; }
  .heroActions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.75rem; }
  .heroImage { width: min(100%, 380px); border-radius: 24px; object-fit: cover; margin: 0 auto; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18); }
  .heroImageFlat { box-shadow: none; }
  @media (max-width: 900px) {
    .heroText { font-size: 1rem; }
  }
</style>
