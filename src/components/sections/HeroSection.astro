---
import Hero from '@/components/Hero.astro';
import Button from '@/components/Button.astro';

interface Action {
  label: string;
  href: string;
}

interface Props {
  section: {
    eyebrow?: string;
    title: string;
    text?: string;
    image?: string;
    actions?: Action[];
  };
  fallbackImage?: string;
}

const { section, fallbackImage = '/assets/Sand.jpeg' } = Astro.props;
const imageUrl = section?.image?.asset?.url || section?.image || fallbackImage;
const actions = section?.actions ?? [];
---

<Hero id="hero" backgroundImage={fallbackImage} theme="tertiary" backgroundParallax={true}>
  <div slot="left" class="heroContent">
    {section?.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
    <h1 class="heroTitle">{section?.title}</h1>
    {section?.text && <p class="heroText">{section.text}</p>}
    {actions.length > 0 && (
      <div class="heroActions">
        {actions.map((action) => <Button label={action.label} href={action.href} theme="primary" />)}
      </div>
    )}
  </div>
  {imageUrl && <img slot="right" class="heroImage" src={imageUrl} alt={section?.title ?? 'Hero image'} />}
</Hero>

<style>
  .heroContent { max-width: 720px; display: flex; flex-direction: column; gap: 1rem; }
  .eyebrow { margin: 0; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.85rem; font-weight: 700; opacity: 0.8; }
  .heroTitle { margin: 0; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.05; }
  .heroText { margin: 0; font-size: 1.1rem; line-height: 1.75; max-width: 62ch; }
  .heroActions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.75rem; }
  .heroImage { width: min(100%, 380px); border-radius: 24px; object-fit: cover; margin: 0 auto; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18); }
  @media (max-width: 900px) {
    .heroText { font-size: 1rem; }
  }
</style>
