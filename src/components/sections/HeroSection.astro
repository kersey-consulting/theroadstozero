---
import Hero from '@/components/Hero.astro';
import Button from '@/components/Button.astro';
import { urlFor } from '@/lib/sanity';

interface Action {
  label: string;
  href: string;
}

interface Props {
  section: {
    eyebrow?: string;
    title: string;
    text?: string;
    image?: any;
    imagePosition?: 'left' | 'right';
    backgroundImage?: any;
    actions?: Action[];
  };
}

const { section } = Astro.props;
const resolveImageUrl = (img: any) => {
  if (!img) return undefined;
  if (typeof img === 'string') return img;
  if (img.asset?.url) return img.asset.url;
  try {
    return urlFor(img).url();
  } catch {
    return undefined;
  }
};

const imageUrl = resolveImageUrl(section?.image);
const backgroundImageUrl = resolveImageUrl(section?.backgroundImage);
const actions = section?.actions ?? [];
const hasImage = Boolean(imageUrl);
const reverse = section?.imagePosition === 'left';
---

<Hero id="hero" backgroundImage={backgroundImageUrl} theme="tertiary" backgroundParallax={true} hasRightColumn={hasImage} reverse={reverse}>
  <div slot="left" class:list={['heroContent', !hasImage && 'fullWidth']}>
    {section?.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
    <h1 class="heroTitle">{section?.title}</h1>
    {section?.text && <p class="heroText">{section.text}</p>}
    {actions.length > 0 && (
      <div class="heroActions">
        {actions.map((action) => <Button label={action.label} href={action.href} theme="primary" />)}
      </div>
    )}
  </div>
  {imageUrl && <img slot="right" class="heroImage" src={imageUrl} alt={section?.title ?? 'Hero image'} />}
</Hero>

<style>
  .heroContent { max-width: 720px; display: flex; flex-direction: column; gap: 1rem; }
  .heroContent.fullWidth { max-width: 100%; }
  .eyebrow { margin: 0; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.85rem; font-weight: 700; opacity: 0.8; }
  .heroTitle { margin: 0; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.05; }
  .heroText { margin: 0; font-size: 1.1rem; line-height: 1.75; }
  .heroActions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.75rem; }
  .heroImage { width: min(100%, 380px); border-radius: 24px; object-fit: cover; margin: 0 auto; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18); }
  @media (max-width: 900px) {
    .heroText { font-size: 1rem; }
  }
</style>
