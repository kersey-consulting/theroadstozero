---
import BaseLayout from './BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Button from '@/components/Button.astro';
import { getSanityClient, queries } from '@/lib/sanity';

const sanityClient = getSanityClient(Astro.locals.runtime?.env);
const settings = await sanityClient.fetch(queries.siteSettings).catch(() => null);

export interface Benefit {
  title: string;
  description: string;
}

export interface AddOn {
  name: string;
  detail: string;
}

export interface ServicePageData {
  type: 'IV Drip' | 'IM Injection';
  name: string;
  tagline: string;
  heroText: string;
  description: string[];
  benefits: Benefit[];
  addOns?: AddOn[];
  pairWith?: string[];
  requiresConsultation?: boolean;
  heroImage?: string;
}

interface Props {
  data: ServicePageData;
}

const { data } = Astro.props;
const bookingUrl = settings?.bookingUrl ?? 'https://booking.hydreight.com/widget-business/fk58k';
---

<BaseLayout title={`${data.name} — The Road to Zero`} description={data.heroText}>
  <div class="page">
    <Hero id="hero" backgroundImage={data.heroImage ?? '/assets/Sand.jpeg'} backgroundParallax={true} theme="tertiary" hasRightColumn={false}>
      <div slot="left" class="heroContent">
        <div class="breadcrumb">
          <a href="/services/iv-therapy">← IV Therapy & Vitamin Injections</a>
        </div>
        <span class="typeTag">{data.type}</span>
        <h1 class="heroTitle">{data.name}</h1>
        <p class="heroTagline">{data.tagline}</p>
        <p class="heroText">{data.heroText}</p>
        <div class="heroActions">
          <Button label="Book This Treatment" href={bookingUrl} theme="primary" />
          <Button label="View All IV Services" href="/services/iv-therapy" theme="primary" />
        </div>
      </div>
    </Hero>

    <section id="about" class="descriptionSection">
      <div class="narrow">
        <h2 class="sectionTitle">About This Treatment</h2>
        <div class="copy">
          {data.description.map((para) => <p>{para}</p>)}
        </div>
        {data.requiresConsultation && (
          <div class="consultationNote">
            A consultation is required prior to this treatment. Please contact us to schedule.
          </div>
        )}
      </div>
    </section>

    <section id="benefits" class="benefitsSection">
      <div class="narrow">
        <h2 class="sectionTitle">Key Benefits</h2>
        <div class="benefitsGrid">
          {data.benefits.map((benefit) => (
            <div class="benefitCard">
              <h3>{benefit.title}</h3>
              <p>{benefit.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {data.addOns && data.addOns.length > 0 && (
      <section id="add-ons" class="addOnsSection">
        <div class="narrow">
          <h2 class="sectionTitle">Available Add-Ons</h2>
          <p class="addOnsIntro">
            Customize your treatment with targeted add-ons for deeper, more personalized results.
          </p>
          <div class="addOnsGrid">
            {data.addOns.map((addon) => (
              <div class="addOnCard">
                <h4>{addon.name}</h4>
                <p>{addon.detail}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {data.pairWith && data.pairWith.length > 0 && (
      <section id="pair-with" class="pairSection">
        <div class="narrow">
          <h2 class="sectionTitleCentered">Pairs Well With</h2>
          <p class="centeredText">Enhance your results by combining this treatment with:</p>
          <div class="pairTags">
            {data.pairWith.map((service) => (
              <span class="pairTag">{service}</span>
            ))}
          </div>
        </div>
      </section>
    )}

    <section id="book" class="ctaSection">
      <div class="ctaCard">
        <h2>Ready to Begin?</h2>
        <p>Book your {data.name} session today. We come to you — home, office, or wellness studio.</p>
        <div class="ctaActions">
          <Button label="Book This Treatment" href={bookingUrl} theme="primary" />
          <Button label="View All IV Services" href="/services/iv-therapy" theme="primary" />
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page { display: flex; flex-direction: column; }
  .heroContent { max-width: 100%; display: flex; flex-direction: column; gap: 1rem; }
  .breadcrumb { font-size: 0.9rem; font-weight: 600; opacity: 0.75; }
  .breadcrumb a { color: inherit; text-decoration: none; transition: opacity 0.15s ease; }
  .breadcrumb a:hover { opacity: 1; }
  .typeTag {
    display: inline-flex; align-items: center;
    padding: 0.3rem 0.85rem; border-radius: 999px;
    background: rgba(210, 185, 150, 0.22);
    font-size: 0.78rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em; width: fit-content;
  }
  .heroTitle { margin: 0; font-size: clamp(2.25rem, 5vw, 3.5rem); line-height: 1.05; }
  .heroTagline { margin: 0; font-size: 1.15rem; font-style: italic; opacity: 0.75; }
  .heroText { margin: 0; font-size: 1.05rem; line-height: 1.8; max-width: 64ch; }
  .heroActions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.5rem; }
  .descriptionSection, .benefitsSection, .addOnsSection, .pairSection, .ctaSection { padding: 5rem 1.5rem; }
  .benefitsSection { background: rgba(210, 185, 150, 0.10); }
  .pairSection { background: rgba(210, 185, 150, 0.06); }
  .narrow { width: min(100%, 1000px); margin: 0 auto; }
  .sectionTitle { margin: 0 0 2rem; font-size: clamp(1.75rem, 3.5vw, 2.5rem); line-height: 1.15; }
  .sectionTitleCentered { margin: 0 0 1rem; font-size: clamp(1.75rem, 3.5vw, 2.5rem); line-height: 1.15; text-align: center; }
  .copy { display: flex; flex-direction: column; gap: 1.1rem; }
  .copy p { margin: 0; font-size: 1.05rem; line-height: 1.85; }
  .consultationNote {
    margin-top: 1.75rem; padding: 1.25rem 1.5rem;
    background: rgba(112, 94, 35, 0.07);
    border-left: 4px solid var(--color-secondary);
    border-radius: 0 12px 12px 0;
    font-size: 0.97rem; font-weight: 600; line-height: 1.6;
  }
  .benefitsGrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
  .benefitCard {
    background: white; border-radius: 18px; padding: 1.75rem;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.07);
    border-top: 3px solid var(--color-secondary);
  }
  .benefitCard h3 { margin: 0 0 0.6rem; font-size: 1.05rem; color: var(--color-primary); }
  .benefitCard p { margin: 0; font-size: 0.93rem; line-height: 1.7; opacity: 0.85; }
  .addOnsIntro { margin: 0 0 2rem; font-size: 1.05rem; line-height: 1.75; opacity: 0.85; }
  .addOnsGrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.1rem; }
  .addOnCard { background: white; border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06); }
  .addOnCard h4 { margin: 0 0 0.5rem; font-size: 1rem; color: var(--color-secondary); }
  .addOnCard p { margin: 0; font-size: 0.9rem; line-height: 1.65; opacity: 0.8; }
  .centeredText { text-align: center; margin: 0 0 1.75rem; font-size: 1rem; line-height: 1.75; opacity: 0.8; }
  .pairTags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.85rem; }
  .pairTag {
    display: inline-flex; align-items: center;
    padding: 0.7rem 1.25rem; border-radius: 999px;
    background: white; border: 2px solid var(--color-secondary);
    font-weight: 600; font-size: 0.95rem; color: var(--color-primary);
  }
  .ctaCard {
    width: min(100%, 900px); margin: 0 auto; text-align: center;
    background: white; border-radius: 24px; padding: 3rem 2rem;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.09);
  }
  .ctaCard h2 { margin: 0 0 0.75rem; font-size: clamp(1.75rem, 3vw, 2.5rem); }
  .ctaCard p { margin: 0 auto 2rem; font-size: 1.05rem; line-height: 1.75; opacity: 0.8; max-width: 580px; }
  .ctaActions { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; }
  @media (max-width: 768px) {
    .descriptionSection, .benefitsSection, .addOnsSection, .pairSection, .ctaSection { padding: 3.5rem 1.25rem; }
    .heroText { font-size: 1rem; }
    .benefitsGrid { grid-template-columns: 1fr; }
    .ctaCard { padding: 2.5rem 1.5rem; }
  }
</style>
