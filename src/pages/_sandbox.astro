---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSections from '@/components/sections/PageSections.astro';
import { getSanityClient, queries } from '@/lib/sanity';

const sanityClient = getSanityClient(Astro.locals.runtime?.env);
const page = await sanityClient.fetch(queries.pageBySlug, { slug: '_sandbox' }).catch(() => null);
const staffMembers = await sanityClient.fetch(queries.staffMembers).catch(() => []);
---

<BaseLayout title={page?.seo?.title ?? page?.title ?? 'SANDBOX'} description={page?.seo?.description ?? ''}>
  <PageSections sections={page?.sections ?? []} staffMembers={staffMembers} />
</BaseLayout>
