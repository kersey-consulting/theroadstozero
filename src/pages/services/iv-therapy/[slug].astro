---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSections from '@/components/sections/PageSections.astro';
import { getSanityClient, queries } from '@/lib/sanity';

export async function getStaticPaths() {
  const sanityClient = getSanityClient(Astro.locals.runtime?.env);
  const allServices = await sanityClient.fetch(
    `*[_type == "service" && category->slug.current == "iv-therapy"]{
      "slug": slug.current
    } | order(order asc)`
  ).catch(() => []);

  return allServices
    .filter((service: any) => service.slug)
    .map((service: any) => ({
      params: { slug: service.slug },
    }));
}

const sanityClient = getSanityClient(Astro.locals.runtime?.env);
const { slug } = Astro.params;
const service = await sanityClient.fetch(queries.serviceBySlug, { slug }).catch(() => null);
const staffMembers = await sanityClient.fetch(queries.staffMembers).catch(() => []);
---

<BaseLayout title={service?.seo?.title ?? service?.name ?? 'Service'} description={service?.seo?.description ?? service?.shortDescription ?? service?.heroText ?? ''}>
  <PageSections sections={service?.sections ?? []} staffMembers={staffMembers} />
</BaseLayout>
