---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSections from '@/components/sections/PageSections.astro';
import { sanityClient, queries } from '@/lib/sanity';

export async function getStaticPaths() {
  const categories = await sanityClient.fetch(`*[_type == "serviceCategory"]{ "slug": slug.current }`).catch(() => []);

  return categories
    .filter((category: any) => category.slug && category.slug !== 'iv-therapy')
    .map((category: any) => ({
      params: { slug: category.slug },
    }));
}

const { slug } = Astro.params;
const category = await sanityClient.fetch(queries.serviceCategoryBySlug, { slug }).catch(() => null);
---

<BaseLayout title={category?.seo?.title ?? `${category?.title ?? 'Service Category'} — The Road to Zero`} description={category?.seo?.description ?? category?.description ?? ''}>
  <PageSections sections={category?.sections ?? []} />
</BaseLayout>
