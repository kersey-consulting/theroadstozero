---
import ServiceHubLayout from '@/layouts/ServiceHubLayout.astro';
import Hero from '@/components/Hero.astro';
import Button from '@/components/Button.astro';
import { sanityClient, queries } from '@/lib/sanity';

const settings = await sanityClient.fetch(queries.siteSettings).catch(() => null);
const category = await sanityClient.fetch(queries.serviceCategoryBySlug, { slug: 'aesthetic-treatments' }).catch(() => null);
const bookingUrl = settings?.bookingUrl ?? 'https://booking.hydreight.com/widget-business/fk58k';

const treatments = category?.services ?? [];
const introBody = category?.introBody?.map((b: any) => b.children?.map((c: any) => c.text).join('')).filter(Boolean) ?? [];
const supportItems = category?.supportingItems ?? [];
const infoCards = category?.infoCards ?? [];
---

<ServiceHubLayout title="Aesthetic Treatments — The Road to Zero" description={category?.description ?? 'Subtle, natural-looking enhancements designed to restore balance and refresh your appearance.'}>
  <Hero id="hero" backgroundImage={category?.heroImage ?? '/assets/Sand.jpeg'} backgroundParallax={true} theme="tertiary">
    <div slot="left" class="hub-heroContent">
      <p class="hub-eyebrow">{category?.eyebrow ?? 'Services'}</p>
      <h1 class="hub-heroTitle">{category?.heroTitle ?? 'Aesthetic Treatments'}</h1>
      <p class="hub-heroText">{category?.heroText ?? 'Subtle, natural-looking enhancements designed to restore balance and refresh your appearance — without looking overdone. Because true beauty is a return to your most vibrant, natural self.'}</p>
      <div class="hub-heroActions">
        <Button label="Book a Consultation" href={bookingUrl} theme="primary" />
        <Button label="View All Services" href="/services" theme="primary" />
      </div>
    </div>
  </Hero>

  <section class="hub-section">
    <div class="hub-narrow">
      <h2 class="hub-sectionTitle">{category?.introTitle ?? 'Our Philosophy on Aesthetics'}</h2>
      <div class="hub-copy">{introBody.map((p: string) => <p>{p}</p>)}</div>
    </div>
  </section>

  <section class="hub-sectionAlt">
    <div class="hub-wide">
      <h2 class="hub-sectionTitle">{category?.cardSectionTitle ?? 'Treatments Offered'}</h2>
      <p class="hub-sectionSubtitle">{category?.cardSectionSubtitle ?? 'All treatments are performed by or under the supervision of a licensed medical provider. A consultation is required prior to treatment.'}</p>
      <div class="hub-treatmentsGrid">
        {treatments.map((t: any) => (
          <div class="hub-treatmentCard">
            <span class="hub-cardTag">{t.tagline ?? t.type}</span>
            <h3>{t.name}</h3>
            <p>{t.shortDescription}</p>
            <ul>{(t.keyBenefits ?? []).map((h: string) => <li>{h}</li>)}</ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="hub-section">
    <div class="hub-narrow">
      <h2 class="hub-sectionTitle">{category?.supportingSectionTitle ?? 'Our Approach'}</h2>
      <div class="hub-highlightsGrid">
        {supportItems.map((p: any) => (
          <div class="hub-highlightCard"><h3>{p.title}</h3><p>{p.description}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="hub-sectionAlt">
    <div class="hub-narrow">
      <h2 class="hub-sectionTitle">{category?.secondarySectionTitle ?? 'Credentials & Training'}</h2>
      <div class="hub-copy">{category?.tagSectionIntro && <p>{category.tagSectionIntro}</p>}</div>
      <div class="hub-infoGrid">
        {infoCards.map((card: any) => (
          <div class="hub-infoCard"><h3>{card.title}</h3><ul class="hub-infoList">{(card.items ?? []).map((item: string) => <li>{item}</li>)}</ul></div>
        ))}
      </div>
    </div>
  </section>

  <section class="hub-section">
    <div class="hub-ctaCard">
      <h2>{category?.ctaTitle ?? 'Ready to Begin Your Aesthetic Journey?'}</h2>
      <p>{category?.ctaText ?? 'Book a personalized consultation with Rachel and discover what\'s possible with a conservative, natural approach to aesthetic care.'}</p>
      <div class="hub-ctaActions">
        <Button label={category?.ctaPrimaryLabel ?? 'Book a Consultation'} href={category?.ctaPrimaryHref ?? bookingUrl} theme="primary" />
        <Button label={category?.ctaSecondaryLabel ?? 'Learn About Rachel'} href={category?.ctaSecondaryHref ?? '/about'} theme="primary" />
      </div>
    </div>
  </section>
</ServiceHubLayout>
