---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageSections from '@/components/sections/PageSections.astro';
import { sanityClient, queries } from '@/lib/sanity';

const page = await sanityClient.fetch(queries.pageBySlug, { slug: 'about' }).catch(() => null);
const staffMembers = await sanityClient.fetch(queries.staffMembers).catch(() => []);
---

<BaseLayout title={page?.seo?.title ?? 'About — The Road to Zero'} description={page?.seo?.description ?? 'Compassionate care for the whole person.'}>
  <PageSections sections={page?.sections ?? []} staffMembers={staffMembers} />
</BaseLayout>
