---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Button from '@/components/Button.astro';
import { sanityClient, queries } from '@/lib/sanity';

const settings = await sanityClient.fetch(queries.siteSettings).catch(() => null);
const page = await sanityClient.fetch(queries.pageBySlug, { slug: 'about' }).catch(() => null);
const staffMembers = await sanityClient.fetch(queries.staffMembers).catch(() => []);
const bookingUrl = settings?.bookingUrl ?? 'https://booking.hydreight.com/widget-business/fk58k';

const sections = page?.sections ?? [];
const hero = sections.find((s: any) => s._type === 'heroSection');
const story = sections.find((s: any) => s._type === 'richTextSection' && s._key === 'story');
const staffSection = sections.find((s: any) => s._type === 'staffSection');
const credentials = sections.find((s: any) => s._type === 'cardsSection');
const approach = sections.find((s: any) => s._type === 'richTextSection' && s._key === 'approach');
const approachTags = sections.find((s: any) => s._type === 'tagListSection' && s._key === 'approach-tags');
const services = sections.find((s: any) => s._type === 'tagListSection' && s._key === 'services');
const cta = sections.find((s: any) => s._type === 'ctaSection');

const featuredStaff = (staffSection?.staffMembers ?? []).map((ref: any) =>
  staffMembers.find((s: any) => s._id === ref._ref)
).filter(Boolean);
const featured = featuredStaff[0] ?? staffMembers.find((s: any) => s.name === 'Rachel');

const blockText = (blocks: any[] = []) =>
  blocks.map((b) => b.children?.map((c: any) => c.text).join('')).filter(Boolean);
---

<BaseLayout title={page?.seo?.title ?? 'About — The Road to Zero'} description={page?.seo?.description ?? 'Compassionate care for the whole person.'}>
  <div class="page">
    <Hero id="hero" backgroundImage="/assets/Sand.jpeg" theme="tertiary" backgroundParallax={true}>
      <div slot="left" class="heroContent">
        <p class="eyebrow">{hero?.eyebrow ?? 'About the founder & owner'}</p>
        <h1 class="heroTitle">{hero?.title ?? 'Compassionate care for the whole person'}</h1>
        <p class="heroText">{hero?.text ?? 'RN, Midwife, licensed healthcare administrator, Botulinum and Dermal Filler clinician, certified IV therapy provider, and Reiki practitioner.'}</p>
        <div class="heroActions">
          {(hero?.actions ?? [
            { label: 'Book a Consultation', href: bookingUrl },
            { label: 'Explore Services', href: '/services' },
          ]).map((action: any) => (
            <Button label={action.label} href={action.href} theme="primary" />
          ))}
        </div>
      </div>
      {featured?.photo && <img slot="right" class="heroImage" src={featured.photo} alt={featured.name} />}
    </Hero>

    <section id="story" class="section">
      <div class="narrow">
        <h2 class="sectionTitle">{story?.title ?? 'A life devoted to caring for others'}</h2>
        <div class="copy">
          {blockText(story?.content).map((p: string) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <section id="featured-staff" class="sectionAlt">
      <div class="narrow">
        <h2 class="sectionTitleCentered">{staffSection?.title ?? 'Featured Clinician'}</h2>
        {staffSection?.intro && <p class="centeredText">{staffSection.intro}</p>}
        {featured && (
          <div class="featuredCard">
            {featured.photo && <img class="featuredImage" src={featured.photo} alt={featured.name} />}
            <div class="featuredBody">
              <h3>{featured.name}</h3>
              {featured.role && <p class="featuredRole">{featured.role}</p>}
              {featured.credentials && <p class="featuredCredentials">{featured.credentials}</p>}
              <div class="copy">
                {blockText(featured.bio).map((p: string) => <p>{p}</p>)}
              </div>
            </div>
          </div>
        )}
      </div>
    </section>

    <section id="credentials" class="section">
      <div class="narrow">
        <h2 class="sectionTitleCentered">{credentials?.title ?? 'Credentials & Specialties'}</h2>
        <div class="credentialsGrid">
          {(credentials?.cards ?? []).map((card: any) => (
            <div class="card">
              <h3>{card.title}</h3>
              <ul class="list">{String(card.description || '').split('\n').filter(Boolean).map((line: string) => <li>{line}</li>)}</ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Hero id="approach" theme="tertiary">
      <div slot="left" class="storyBlock">
        <h2 class="sectionTitle">{approach?.title ?? 'A holistic approach to wellness and confidence'}</h2>
        <div class="copy">
          {blockText(approach?.content).map((p: string) => <p>{p}</p>)}
        </div>
      </div>
      <div slot="right" class="valuesCard">
        <h3 class="valuesTitle">{approachTags?.title ?? 'What clients may be looking for'}</h3>
        <ul class="list">{(approachTags?.tags ?? []).map((tag: string) => <li>{tag}</li>)}</ul>
      </div>
    </Hero>

    <section id="services" class="section">
      <div class="narrow">
        <h2 class="sectionTitleCentered">{services?.title ?? 'Services Rachel is honored to offer'}</h2>
        <div class="serviceTags">{(services?.tags ?? []).map((tag: string) => <span class="tag">{tag}</span>)}</div>
        {services?.intro && <p class="centeredText">{services.intro}</p>}
      </div>
    </section>

    <section id="book" class="section">
      <div class="ctaCard">
        <h2 class="sectionTitleCentered">{cta?.title ?? 'Thank you for trusting Rachel with your wellness journey'}</h2>
        <p class="centeredText">{cta?.text ?? 'If you are ready to feel more rejuvenated, confident, and supported, Rachel would be honored to walk alongside you.'}</p>
        <div class="ctaActions">
          {(cta?.actions ?? [
            { label: 'Book Appointment', href: bookingUrl },
            { label: 'View Services', href: '/services' },
          ]).map((action: any) => (
            <Button label={action.label} href={action.href} theme="primary" />
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page { display: flex; flex-direction: column; gap: 0; }
  .heroContent { max-width: 720px; display: flex; flex-direction: column; gap: 1rem; }
  .eyebrow { margin: 0; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.85rem; font-weight: 700; opacity: 0.8; }
  .heroTitle { margin: 0; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.05; }
  .heroText { margin: 0; font-size: 1.1rem; line-height: 1.75; max-width: 62ch; }
  .heroActions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.75rem; }
  .heroImage { width: min(100%, 380px); border-radius: 24px; object-fit: cover; margin: 0 auto; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18); }
  .section, .sectionAlt { padding: 5rem 1.5rem; }
  .sectionAlt { background: rgba(210, 185, 150, 0.12); }
  .narrow { width: min(100%, 1000px); margin: 0 auto; }
  .sectionTitle, .sectionTitleCentered { margin: 0 0 1.5rem; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; }
  .sectionTitleCentered { text-align: center; }
  .copy { display: flex; flex-direction: column; gap: 1rem; }
  .copy p, .centeredText { margin: 0; font-size: 1.05rem; line-height: 1.85; }
  .centeredText { text-align: center; max-width: 760px; margin-left: auto; margin-right: auto; }
  .credentialsGrid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.5rem; margin-top: 2rem; }
  .card, .valuesCard, .ctaCard, .featuredCard { background: white; border-radius: 24px; padding: 2rem; box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08); }
  .card h3, .valuesTitle { margin: 0 0 1rem; font-size: 1.25rem; }
  .list { margin: 0; padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; line-height: 1.7; }
  .storyBlock { max-width: 720px; }
  .serviceTags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.85rem; margin: 2rem 0 1.5rem; }
  .tag { display: inline-flex; align-items: center; padding: 0.8rem 1.1rem; border-radius: 999px; background: rgba(210, 185, 150, 0.18); font-weight: 600; }
  .ctaCard { width: min(100%, 960px); margin: 0 auto; text-align: center; }
  .ctaActions { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; margin-top: 2rem; }
  .featuredCard { display: grid; grid-template-columns: 280px 1fr; gap: 2rem; align-items: start; }
  .featuredImage { width: 100%; border-radius: 20px; object-fit: cover; }
  .featuredBody h3 { margin: 0 0 0.5rem; }
  .featuredRole, .featuredCredentials { margin: 0 0 0.75rem; opacity: 0.85; }
  @media (max-width: 900px) {
    .credentialsGrid { grid-template-columns: 1fr; }
    .featuredCard { grid-template-columns: 1fr; }
    .section, .sectionAlt { padding: 4rem 1.25rem; }
    .heroText { font-size: 1rem; }
  }
</style>
