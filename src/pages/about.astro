---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Button from '@/components/Button.astro';
import { sanityClient, queries } from '@/lib/sanity';

const settings = await sanityClient.fetch(queries.siteSettings).catch(() => null);
const staffMembers = await sanityClient.fetch(queries.staffMembers).catch(() => []);
const rachel = staffMembers?.find((s: any) => s.name === 'Rachel');
const rachelPhoto = rachel?.photo ?? '/assets/MyPicture_356x475.jpeg';

const bookingUrl = settings?.bookingUrl ?? 'https://booking.hydreight.com/widget-business/fk58k';
---

<BaseLayout title="About — The Road to Zero" description="Compassionate care for the whole person.">
  <div class="page">
    <Hero id="hero" backgroundImage="/assets/Sand.jpeg" theme="tertiary" backgroundParallax={true}>
      <div slot="left" class="heroContent">
        <p class="eyebrow">About the founder & owner</p>
        <h1 class="heroTitle">Compassionate care for the whole person</h1>
        <p class="heroText">RN, Midwife, licensed healthcare administrator, Botulinum and Dermal Filler clinician, certified IV therapy provider, and Reiki practitioner.</p>
        <p class="heroText">Rachel's mission is to help clients feel rejuvenated, confident, and aligned through personalized care that supports mind, body, and spirit.</p>
        <div class="heroActions">
          <Button label="Book a Consultation" href={bookingUrl} theme="primary" />
          <Button label="Explore Services" href="/services" theme="primary" />
        </div>
      </div>
      <img slot="right" class="heroImage" src={rachelPhoto} alt="Rachel" />
    </Hero>

    <section id="story" class="section">
      <div class="narrow">
        <h2 class="sectionTitle">A life devoted to caring for others</h2>
        <div class="copy">
          <p>Rachel has had the blessing of supporting life at both its beginning and its end. Welcoming new life into the world as a midwife and walking alongside individuals and families during the end-of-life journey in hospice care.</p>
          <p>These experiences gave her a deep appreciation for the full spectrum of life and a compassionate understanding of what it means to truly care for others.</p>
          <p>Her personal journey began with a search for balance, self-discovery, self-love, and healing. Over time, that journey evolved into a professional mission: creating a safe, nurturing, and holistic space where wellness begins from within.</p>
        </div>
      </div>
    </section>

    <section id="credentials" class="sectionAlt">
      <div class="narrow">
        <h2 class="sectionTitleCentered">Credentials & Specialties</h2>
        <div class="credentialsGrid">
          <div class="card">
            <h3>Clinical Background</h3>
            <ul class="list"><li>Registered Nurse</li><li>Midwife</li><li>Licensed healthcare Administrator</li></ul>
          </div>
          <div class="card">
            <h3>Credentials</h3>
            <ul class="list"><li>AACM (American Academy of Cosmetic medicine)</li><li>AMET (Aesthetic Medical Educators training)</li><li>Empire Medical</li></ul>
          </div>
          <div class="card">
            <h3>Specialties</h3>
            <ul class="list"><li>Aesthetics Specialist</li><li>Dermal Filler clinician</li><li>Reiki practitioner</li></ul>
          </div>
        </div>
      </div>
    </section>

    <Hero id="approach" theme="tertiary">
      <div slot="left" class="storyBlock">
        <h2 class="sectionTitle">A holistic approach to wellness and confidence</h2>
        <div class="copy">
          <p>Whether you are seeking stress relief, emotional or physical balance, increased energy, hormone support, weight management, or cosmetic rejuvenation, Rachel's goal is to guide you toward feeling your absolute best.</p>
          <p>Her approach blends medical knowledge, aesthetic expertise, and holistic care to support lasting wellness from the inside out.</p>
          <p>Every experience is designed to feel personal, supportive, and grounded in compassion.</p>
        </div>
      </div>
      <div slot="right" class="valuesCard">
        <h3 class="valuesTitle">What clients may be looking for</h3>
        <ul class="list">
          <li>Stress relief and renewed balance</li>
          <li>Improved energy and recovery</li>
          <li>Hormone and wellness support</li>
          <li>Weight management guidance</li>
          <li>Natural-looking cosmetic rejuvenation</li>
          <li>Mind, body, and spirit alignment</li>
        </ul>
      </div>
    </Hero>

    <section id="services" class="section">
      <div class="narrow">
        <h2 class="sectionTitleCentered">Services Rachel is honored to offer</h2>
        <div class="serviceTags">
          <span class="tag">IV Therapy</span>
          <span class="tag">GLP-1 Medications</span>
          <span class="tag">Peptides</span>
          <span class="tag">Aesthetic Treatments</span>
          <span class="tag">Botulinum</span>
          <span class="tag">Dermal Fillers</span>
          <span class="tag">Reiki</span>
        </div>
        <p class="centeredText">Rachel looks forward to sharing the restorative and empowering benefits of these services in a way that feels thoughtful, personalized, and aligned with each client's goals.</p>
      </div>
    </section>

    <section id="book" class="section">
      <div class="ctaCard">
        <h2 class="sectionTitleCentered">Thank you for trusting Rachel with your wellness journey</h2>
        <p class="centeredText">If you are ready to feel more rejuvenated, confident, and supported, Rachel would be honored to walk alongside you.</p>
        <div class="ctaActions">
          <Button label="Book Appointment" href={bookingUrl} theme="primary" />
          <Button label="View Services" href="/services" theme="primary" />
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page { display: flex; flex-direction: column; gap: 0; }
  .heroContent { max-width: 720px; display: flex; flex-direction: column; gap: 1rem; }
  .eyebrow { margin: 0; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.85rem; font-weight: 700; opacity: 0.8; }
  .heroTitle { margin: 0; font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.05; }
  .heroText { margin: 0; font-size: 1.1rem; line-height: 1.75; max-width: 62ch; }
  .heroActions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.75rem; }
  .heroImage { width: min(100%, 380px); border-radius: 24px; object-fit: cover; margin: 0 auto; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18); }
  .section, .sectionAlt { padding: 5rem 1.5rem; }
  .sectionAlt { background: rgba(210, 185, 150, 0.12); }
  .narrow { width: min(100%, 1000px); margin: 0 auto; }
  .sectionTitle, .sectionTitleCentered { margin: 0 0 1.5rem; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; }
  .sectionTitleCentered { text-align: center; }
  .copy { display: flex; flex-direction: column; gap: 1rem; }
  .copy p, .centeredText { margin: 0; font-size: 1.05rem; line-height: 1.85; }
  .centeredText { text-align: center; max-width: 760px; margin-left: auto; margin-right: auto; }
  .credentialsGrid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.5rem; margin-top: 2rem; }
  .card, .valuesCard, .ctaCard { background: white; border-radius: 24px; padding: 2rem; box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08); }
  .card h3, .valuesTitle { margin: 0 0 1rem; font-size: 1.25rem; }
  .list { margin: 0; padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; line-height: 1.7; }
  .storyBlock { max-width: 720px; }
  .serviceTags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.85rem; margin: 2rem 0 1.5rem; }
  .tag { display: inline-flex; align-items: center; padding: 0.8rem 1.1rem; border-radius: 999px; background: rgba(210, 185, 150, 0.18); font-weight: 600; }
  .ctaCard { width: min(100%, 960px); margin: 0 auto; text-align: center; }
  .ctaActions { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; margin-top: 2rem; }
  @media (max-width: 900px) {
    .credentialsGrid { grid-template-columns: 1fr; }
    .section, .sectionAlt { padding: 4rem 1.25rem; }
    .heroText { font-size: 1rem; }
  }
</style>
