---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Button from '@/components/Button.astro';
import { sanityClient, queries } from '@/lib/sanity';

const settings = await sanityClient.fetch(queries.siteSettings).catch(() => null);

const products = [
  {
    imagePath: '/assets/home/Aesthetics.png',
    title: 'Aesthetic Treatments',
    subtext: '<ul><li>Botulinum</li><li>Dermal Fillers</li></ul><br/><p><b>Coming Soon:</b></p><ul><li>PRP hair restoration</li><li>Dermaneedling</li><li>Microdermabrasion</li><li>Chemical Peels</li><li>Facial PRP</li><li>Hair restoration: PDO & PRP</li></ul>',
    href: '/services/aesthetic-treatments',
  },
  {
    imagePath: '/assets/home/Body.png',
    title: 'Body Transformation',
    subtext: '<p><b>Coming Soon:</b></p><ul><li>Body Shaping and Contouring</li><li>Skin Firmness and Tightening</li><li>Fat and Cellulite Reduction</li><li>Facial Toning and Rejuvenation</li><li>Laser treatments</li><li>Hair removal</li><li>Tattoo, Birthmark, Age or sun spot removal</li></ul>',
    href: '/services/body-transformation',
  },
  {
    imagePath: '/assets/home/IV.png',
    title: 'IV Therapy & Vitamin Injections',
    subtext: '<ul><li>Myers Cocktail</li><li>Immunity Boost</li><li>Beauty & Anti-Aging</li><li>Detox & Hangover Recovery</li><li>Athletic Recovery</li></ul>',
    href: '/services/iv-therapy',
  },
  {
    imagePath: '/assets/home/GLP-1.png',
    title: 'Medical Weight Management',
    subtext: '<ul><li>Semaglutide</li><li>Tirzepatide</li></ul>',
    href: '/services/medical-weight-management',
  },
  {
    imagePath: '/assets/home/peptide.png',
    title: 'Peptide & Hormone Support',
    subtext: '<p>Peptide therapy supports natural hormone function, improved recovery, better sleep, and enhanced vitality.</p><p>These treatments help optimize performance, energy levels, and overall wellness.</p>',
    href: '/services/peptide-hormone-support',
  },
  {
    imagePath: '/assets/home/holistic.jpg',
    title: 'Holistic Services',
    subtext: '<p>Healing goes beyond the physical. Rachel\'s holistic services support mind, body, and spirit alignment through Reiki energy healing and integrative wellness sessions.</p><p>Offerings include:</p><ul><li>Reiki energy healing</li><li>Integrative wellness sessions</li><li>Mind-body-spirit alignment</li></ul>',
    href: '/services/holistic-services',
  },
];

const bookingUrl = settings?.bookingUrl ?? 'https://booking.hydreight.com/widget-business/fk58k';
---

<BaseLayout title="The Road to Zero — Aesthetics & Wellness" description="Welcome to our sanctuary for Wellness, Beauty, and Transformative balance.">
  <div class="page">
    <Hero id="hero" theme="tertiary" backgroundParallax={true}>
      <div slot="left">
        <img class="logo" src="/icons/gold-ring-logo.png" alt="The Roads to Zero Logo" />
      </div>
      <div slot="right" style="display: flex; gap: 2rem;">
        <div class="heroContent">
          <p>
            Welcome to our sanctuary for Wellness, Beauty, and Transformative balance. Your journey toward confidence, vitality, and restoration begins here.
            We believe true Glow comes from within, nourishing the body, uplifting the spirit, and enhancing the natural beauty you already possess.
          </p>
          <p>
            With science-backed treatments, a personalized approach, and holistic care, we're here to help you reset, restore, and realign with your best self.
            From IV hydration and peptides to hormone support, GLP therapy, and aesthetic enhancements, every service is crafted to elevate your well-being.
          </p>
          <p>
            Step into a space dedicated to renewal, and allow us to guide you toward total rejuvenation because you deserve to look, feel, and live your most vibrant, balanced, and radiant life.
          </p>
          <div class="heroActions">
            <Button label="Book a Consultation" href={bookingUrl} theme="primary" size="medium" />
            <Button label="Explore Our Services" href="/services" theme="primary" size="medium" />
          </div>
        </div>
      </div>
    </Hero>

    <div class="surfaceContainer">
      <section id="overview" class="section">
        <div class="intro">
          <h2 class="sectionHeader">Restore Balance. Reclaim Vitality. Renew Confidence.</h2>
          <p>
            At The Road to Zero, wellness and aesthetics come together through personalized, medically guided
            care. Our treatments support your body's natural ability to restore balance, recover from stress,
            and enhance your natural beauty.
          </p>
          <p>We focus on:</p>
          <ul class="introList">
            <li>Enhancing natural aesthetics with a conservative approach</li>
            <li>Supporting metabolism, hormones, and recovery</li>
            <li>Restoring hydration, nutrients, and cellular energy</li>
            <li>Guiding you feel aligned in mind, body, and spirit</li>
          </ul>
          <p>Book your consultation and begin your journey back to balance.</p>
          <div class="introAction">
            <Button label="Start Your Wellness Journey" />
          </div>
        </div>
      </section>
    </div>

    <section id="services" class="section">
      <h2 class="sectionHeaderCentered">Our Services</h2>
      <div class="servicesGrid">
        {products.map((product) => (
          <article class="card">
            <img class="cardImage" src={product.imagePath} alt={product.title} />
            <div class="cardContent">
              <h3 class="cardTitle">{product.title}</h3>
              <div class="cardSubtext" set:html={product.subtext} />
              <a class="cardButton" href={product.href}>Learn More</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="why-us" class="section">
      <h2 class="sectionHeader">Why The Road to Zero?</h2>
      <div class="whyIntro">
        <p>The Road to Zero represents a return to balance where health, beauty, and vitality naturally thrive.</p>
        <p>In today's fast-paced world, stress, toxins, inflammation, and lifestyle demands push our bodies away from equilibrium.</p>
        <p>Our mission is to help guide you back.</p>
      </div>
      <div class="valuesGrid">
        <div class="valueCard"><h3>Zero Stress</h3><p>Calming the nervous system and supporting emotional balance.</p></div>
        <div class="valueCard"><h3>Zero Depletion</h3><p>Restoring hydration, essential nutrients, and energy.</p></div>
        <div class="valueCard"><h3>Zero Imbalance</h3><p>Supporting hormonal, metabolic, and cellular health.</p></div>
        <div class="valueCard"><h3>Zero Barriers</h3><p>Providing accessible wellness treatments that meet you where you are.</p></div>
      </div>
      <p class="whyClosing">Healing is a journey, not a shortcut. We are here to walk that road with you.</p>
    </section>

    <Hero id="about" theme="tertiary">
      <div slot="left" class="profileText">
        <h2>About Us</h2>
        <div class="profileCopy">
          <p>RN, Midwife, Certified IV Therapy Provider Botox & Dermal Filler Clinician, Reiki Practitioner</p>
          <p>Rachel has spent her career caring for individuals across the full spectrum of life, from welcoming new life as a midwife to supporting families during end-of-life care in hospice.</p>
          <p>These experiences shaped her deep understanding of what it truly means to care for others.</p>
          <p>Her personal journey of healing and balance inspired the creation of The Road to Zero, a space dedicated to helping individuals restore vitality, confidence, and inner alignment.</p>
          <p>Through personalized wellness therapies and aesthetic treatments, Rachel's mission is to help every client feel their absolute best, mind, body, and spirit.</p>
          <Button label="Learn More About The Road to Zero" href="/about" />
        </div>
      </div>
      <img slot="right" class="profileImage" src="/assets/MyPicture_356x475.jpeg" alt="Rachel" />
    </Hero>

    <div class="surfaceContainer">
      <section id="mobile-services" class="section">
        <div class="mobileServiceCard">
          <div class="mobileServiceContent">
            <h2 class="sectionHeader">We Bring Wellness to You</h2>
            <p>Our concierge services allow you to receive treatments in the comfort of your home or at your business.</p>
            <p>We provide services at:</p>
            <ul class="mobileServiceList">
              <li>Private residences</li>
              <li>Corporate offices</li>
              <li>Spas and salons</li>
              <li>Fitness centers</li>
              <li>Yoga and wellness studios</li>
              <li>Special events and private parties</li>
            </ul>
            <p>Wellness should be convenient, comfortable, and personalized.</p>
            <div class="mobileServiceAction">
              <Button label="Book Mobile Service" href="/mobile-services" />
            </div>
          </div>
        </div>
      </section>
    </div>

    <Hero id="referral" theme="tertiary">
      <div slot="left">
        <h2>Referral Rewards Program</h2>
        <p>Share our aesthetic and wellness services with friends and earn income or complimentary services, Plus earn an ongoing 3% override bonus from referrals your referred clients generate.</p>
        <p>Clients who refer others may receive rewards including:</p>
        <ul>
          <li>Botox treatments</li>
          <li>Dermal fillers</li>
          <li>IV hydration sessions</li>
          <li>Vitamin injections</li>
          <li>Peptide therapy</li>
        </ul>
        <div>
          <Button label="Learn About the Referral Program" href="/referral-program" />
        </div>
      </div>
      <img slot="right" src="/assets/home/Referral.webp" alt="Referral Program" />
    </Hero>

    <section id="book" class="section">
      <div class="finalCta">
        <div class="finalCtaContent">
          <h2 class="finalCtaHeading">Begin Your Journey Back to Balance</h2>
          <p>You deserve to feel energized, confident, and aligned.</p>
          <p>Book your consultation today and take the first step toward restoring your health and vitality.</p>
          <div class="finalCtaAction">
            <Button label="Book Appointment" href={bookingUrl} />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page { display: flex; flex-direction: column; gap: 0; }
  .heroContent { max-width: 900px; margin: 0 auto; }
  .heroActions { display: flex; flex-wrap: wrap; gap: 1rem; margin: 1.5rem 0; }
  .section { width: min(1200px, calc(100% - 4rem)); margin: 0 auto; padding: 4rem 0; }
  .surfaceContainer { background-color: var(--color-surface); }
  .sectionHeader { margin-bottom: 1.5rem; }
  .sectionHeaderCentered { margin-bottom: 2rem; text-align: center; }
  .intro { display: grid; gap: 1.25rem; }
  .introList { padding-left: 1.5rem; display: grid; gap: 0.75rem; }
  .introAction { padding-top: 0.5rem; }
  .servicesGrid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 2rem; }
  .card { display: flex; flex-direction: column; overflow: hidden; background: var(--color-surface); border-radius: 20px; box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.12); height: 100%; }
  .cardImage { display: block; width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
  .cardContent { display: flex; flex: 1; flex-direction: column; align-items: flex-start; gap: 1rem; padding: 1.5rem; }
  .cardTitle { margin: 0; color: var(--color-primary); font-size: 20px; line-height: 1.2; }
  .cardSubtext { flex: 1; margin: 0; color: var(--color-primary); font-size: 16px; }
  .cardButton { display: block; width: 100%; text-align: center; padding: 1rem; color: var(--color-primary); background: transparent; border: 2px solid; border-radius: 15px; }
  .cardButton:hover, .cardButton:focus { background: var(--color-surface); box-shadow: 0 0 10px rgba(0, 0, 0, 0.5); text-decoration: none; }
  .whyIntro { display: grid; gap: 1rem; max-width: 800px; margin-bottom: 2rem; }
  .valuesGrid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
  .valueCard { background: var(--color-surface); border-radius: 20px; padding: 1.5rem; box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.08); display: grid; gap: 0.75rem; }
  .valueCard h3, .valueCard p { margin: 0; }
  .whyClosing { margin-top: 2rem; font-weight: 700; }
  .profileText { max-width: 600px; margin: 0 auto; }
  .profileCopy { display: grid; gap: 1rem; font-size: 1rem; }
  .profileImage { width: min(356px, 100%); height: auto; margin: 0 auto; object-fit: cover; }
  .mobileServiceCard { padding: 2rem; }
  .mobileServiceContent { max-width: 760px; display: grid; gap: 1rem; }
  .mobileServiceList { padding-left: 1.5rem; display: grid; gap: 0.75rem; }
  .mobileServiceAction { padding-top: 0.5rem; }
  .finalCta { background: var(--color-surface); border: 2px solid var(--color-primary); border-radius: 24px; padding: 3rem 2rem; text-align: center; }
  .finalCtaContent { max-width: 760px; margin: 0 auto; display: grid; gap: 1rem; }
  .finalCtaHeading { margin: 0; }
  .finalCtaAction { padding-top: 0.75rem; }
  .logo { max-width: 100%; }
  @media (max-width: 768px) {
    .section { width: min(100% - 2rem, 1200px); padding: 3rem 0; }
    .heroActions { flex-direction: column; align-items: stretch; }
    .sectionHeaderCentered { text-align: left; }
    .mobileServiceCard, .finalCta { padding: 1.5rem; }
  }
</style>
